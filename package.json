{
  "name": "personal-website",
  "version": "1.0.0",
  "scripts": {
    "build:css": "npx tailwindcss -i ./src/public/css/input.css -o ./src/public/css/output.css --minify",
    "watch:css": "npx tailwindcss -i ./src/public/css/input.css -o ./src/public/css/output.css --watch",
    "dev": "concurrently \"npm run watch:css\" \"npx ts-node src/server.ts\"",
    "start": "npx ts-node src/server.ts"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "express": "^4.18.2",
    "helmet": "^7.1.0"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}